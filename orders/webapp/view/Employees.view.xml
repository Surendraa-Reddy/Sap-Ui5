<mvc:View
    controllerName="orders.controller.Employees"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page
        title="Employees"
        class="sapUiResponsiveContentPadding">

        <customHeader>
            <Bar>

                <contentLeft>
                    <Title text="Employees" level="H2"/>
                </contentLeft>

                <contentRight>
                    <Button
                        text="Customers"
                        icon="sap-icon://customer"
                        type="Transparent"
                        press=".onNavigateToCustomers"/>
                </contentRight>

            </Bar>
        </customHeader>

        <content>

            <VBox class="sapUiSmallMargin">

                <SearchField
                    id="employeeSearch"
                    width="100%"
                    placeholder="Search by First Name, Last Name, City or Country"
                    liveChange=".onSearchEmployees"
                    search=".onSearchEmployees"/>

                <Table
                    id="employeesTable"
                    items="{/Employees}"
                    growing="true"
                    growingThreshold="20"
                    growingScrollToLoad="true"
                    inset="false"
                    mode="None"
                    noDataText="No employees found">

                    <headerToolbar>

                        <Toolbar>

                            <Title
                                text="Employee List"
                                level="H2"/>

                            <ToolbarSpacer/>

                            <Button
                                text="Refresh"
                                icon="sap-icon://refresh"
                                press=".onRefresh"/>

                        </Toolbar>

                    </headerToolbar>

                    <columns>

                        <Column width="6rem">
                            <Text text="ID"/>
                        </Column>

                        <Column width="14rem">
                            <Text text="Employee Name"/>
                        </Column>

                        <Column width="14rem">
                            <Text text="Designation"/>
                        </Column>

                        <Column width="10rem">
                            <Text text="City"/>
                        </Column>

                        <Column width="10rem">
                            <Text text="Country"/>
                        </Column>

                        <Column width="12rem">
                            <Text text="Phone"/>
                        </Column>

                         <Column width="12rem">
                            <Text text="Address"/>
                        </Column>

                        <Column width="8rem" hAlign="Center">
                            <Text text="Action"/>
                        </Column>

                    </columns>

                    <items>

                        <ColumnListItem>

                            <cells>

                                <ObjectIdentifier
                                    title="{EmployeeID}"
                                   />

                                <ObjectIdentifier
                                    title="{FirstName} {LastName}"
                                    text="{TitleOfCourtesy}"/>

                                <Text text="{Title}"/>

                                <Text text="{City}"/>

                                <ObjectStatus
                                    text="{Country}"
                                    state="Success"/>

                                <Text text="{HomePhone}"/>
                                <Text text="{Address}"/>

                               <Button
                              text="View"
                               icon="sap-icon://navigation-right-arrow"
                              type="Transparent"
                               press=".onViewEmployee"/>

                            </cells>

                        </ColumnListItem>

                    </items>

                </Table>

            </VBox>

        </content>

    </Page>

</mvc:View>