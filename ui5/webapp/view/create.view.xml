<mvc:View
    controllerName="ui5.controller.create"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core">

    <Page
        title="Create Employee"
        showNavButton="true"
        navButtonPress="backToList">

        <content>
            <form:SimpleForm
                id="createForm"
                editable="true"
                layout="ResponsiveGridLayout"
                title="Employee Details"
                class="sapUiMediumMargin"
                labelSpanL="2"
                labelSpanM="2"
                columnsL="3"
                columnsM="2">

                <form:content>

                    <Label text="Id" required="true"/>
                    <Input id="inpId1" placeholder="Enter Id" width="50%"/>

                    <Label text="Name" required="true"/>
                    <Input id="inpName1" placeholder="Enter Name"  width="50%"/>

                    <Label text="Age" required="true"/>
                    <Input id="inpAge1" placeholder="Enter Age" width="50%"/>

                    <Label text="Email" required="true"/>
                    <Input id="inpEmail1" placeholder="Enter Email" width="50%"/>

                    <Label text="Gender" required="true"/>
                    <Input id="inpGender1" placeholder="Enter Gender" width="50%"/>

                    <Label text="Mobile" required="true"/>
                    <Input id="inpMobile1" placeholder="Enter Mobile" width="50%"/>

                    <Label text="Address" required="true"/>
                    <Input id="inpAddress1" placeholder="Enter Address" width="50%"/>

                </form:content>

            </form:SimpleForm>

            <Table id="projectTable1"  items="{prjModel>/projects}" headerText="Projects" >

            <headerToolbar>
                <Toolbar>
                    <Title text="Projects"/>
                
                <ToolbarSpacer></ToolbarSpacer>
                <Button text="Add Project" type="Emphasized" press="onAddProject
                "/> 
                </Toolbar>
            </headerToolbar>
            <columns>
            <Column >
                <Text text="Id"/>
            </Column>
            <Column >
                <Text text="Project Name"/>
            </Column>
            <Column >
                <Text text="Project Code"/>
            </Column>
            <Column >
                <Text text="Client"/>
            </Column>
            <Column >
                <Text text="Project Description"/>
            </Column>
            <Column >
                <Text text="Team Size"/>
            </Column>
             <Column >
                <Text text="Delete"/>
            </Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Input value="{prjModel>Id}"/>
                        <Input value="{prjModel>ProjectName}"/>
                        <Input value="{prjModel>PrjCode}"/>
                        <Input value="{prjModel>Client}"/>
                        <Input value="{prjModel>PrjDescription}"/>
                        <Input value="{prjModel>TeamSize}"/>
                        <Button icon="sap-icon://delete" type="Reject" press="onDeleteProject"/>
                    </cells>
                </ColumnListItem>
            </items>
            </Table>

            <FlexBox
                justifyContent="Center"
                class="sapUiSmallMargin">

                <Button
                    text="Save"
                    type="Accept"
                    press="onSave"/>

                <Button
                    text="Reset"
                    type="Reject"
                    class="sapUiTinyMarginBegin"
                    press="onReset"/>

            </FlexBox>


           <form:SimpleForm
                id="UploadForm1"
                editable="true"
                layout="ResponsiveGridLayout"
                title="Upload Employee Image"
                class="sapUiMediumMargin"
                labelSpanL="4"
                labelSpanM="4"
                columnsL="3"
                columnsM="3">
                <form:content>
              
                    <Label text="Upload Employee Image" required="true"/>
                    <u:FileUploader id="fileUploader1" name="myFileUpload" uploadUrl="/sap/opu/odata/sap/ZODATA_EMPLOYEE_SRV_01/PhotosSet" sendXHR="true" useMultipart="false"
                     change="onFileChange" uploadComplete="onUploadComplete"/>
                    <Button  id="btnUpload1" text="Upload" press="onUploadfile" type="Emphasized" width="30%"/>

                </form:content>
                </form:SimpleForm>

        </content>
    </Page>

</mvc:View>