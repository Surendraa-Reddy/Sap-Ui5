<mvc:View
    controllerName="ui5.controller.display"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
      xmlns:form="sap.ui.layout.form">

    <Page title="Display Employees" showNavButton="true" navButtonPress="backtotest4">

        <content>
        
           <form:SimpleForm editable="false">
                  
                   <Avatar  id="avatar" src="/sap/opu/odata/sap/ZODATA_EMPLOYEE_SRV_01/PhotosSet({Id})/$value" displaySize="L" visible="true"></Avatar>
                   
                  

    <form:content>
         <Label text="Id"/>
        <Text text="{Id}"/>
        <Label text="Name"/>
        <Text text="{Name}"/>

        <Label text="Age"/>
        <Text text="{Age}"/>

        <Label text="Email"/>
        <Text text="{Email}"/>

        <Label text="Gender"/>
        <Text text="{Gender}"/>

        <Label text="Mobile"/>
        <Text text="{Mobile}"/>

    </form:content>

</form:SimpleForm>
<ScrollContainer  vertical="true" horizontal="true">
<Table  id="projectTable" items="{toprojects}" headerText="Projects" >
    <columns>
    <Column width="20rem"> 
        <Text text="Project Code"/>
    </Column>
    <Column  width="20rem">
        <Text text="Project Name"/>
    </Column>
    <Column width="20rem">
        <Text text="Client"/>
    </Column>
    <Column  width="30rem">
        <Text text="Project Description"/>
    </Column>
    <Column width="20rem">
        <Text text="Team Size"/>
    </Column>
    </columns>
    <items>
        <ColumnListItem>
            <cells>
                <Text text="{PrjCode}"/>
                <Text text="{ProjectName}"/>
                <Text text="{Client}"/>
                <Text text="{PrjDescription}"/>
                <Text text="{TeamSize}"/>
            </cells>
        </ColumnListItem>
    </items>
    
</Table>
</ScrollContainer>


        </content>

    </Page>

</mvc:View>