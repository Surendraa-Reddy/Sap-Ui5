    <Page id="page13" title="Pull the data From Backend "  showNavButton="true" navButtonPress="backtotest3">
   
        <content>
          <form:SimpleForm
                id="simpleForm1"
                title="Employee Details"
                class="sapUiSmallMargin"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanL="5"
                labelSpanM="5"
                emptySpanL="0"
                emptySpanM="0"
                columnsL="3"
                columnsM="2"
            >
                <form:content>
                    <core:Title
                        id="coreTitle1"
                        text="Basic Details"
                    />
                    <Label id="label34" text="Id" required="true"></Label>
                    <Input id="input34" xmlns="sap.m" placeholder="Enter Id"  class="sapUiTinyMarginBegin"></Input>
                    <Label
                        id="label111"
                        text="Name"
                        required="true"
                        
                    />
                    <Input
                        id="input222"
                        xmlns="sap.m"
                        placeholder="Enter Your Name"
                        class="sapUiTinyMarginBegin"
                        enabled="true"
                        maxLength="10"
                    />
                    <Label
                        id="label28"
                        text="Age"
                        required="true"
                       
                    />
                    <Input
                        id="input28"
                        xmlns="sap.m"
                        placeholder="Enter Your Age"
                        class="sapUiTinyMarginBegin"
                        enabled="true"
                    />
                    <core:Title
                        id="coreTitle2"
                        text="Other Details"
                    />
                    <Label
                        id="label29"
                        text="Email"
                        required="true"
                       
                    />
                    <Input
                        id="input29"
                        xmlns="sap.m"
                        placeholder="Enter Your Email"
                        class="sapUiTinyMarginBegin"
                        enabled="true"
                    />

                    <Label
                        id="label30"
                        text="Mobile"
                        required="true"
                        
                    />
                    <Input
                        id="input30"
                        xmlns="sap.m"
                        placeholder="Enter Your Mobile"
                        class="sapUiTinyMarginBegin"
                        enabled="true"
                        maxLength="10"
                    />
                    <Label
                        id="label31"
                        text="Gender"
                        required="true"
                        
                    />
                    <Input
                        id="input31"
                        xmlns="sap.m"
                        placeholder="Enter Your Gender"
                        class="sapUiTinyMarginBegin"
                        enabled="true"
                    />
                    <core:Title
                        id="coreTitle3"
                        text="Address Details"
                    />
                    <Label
                        id="label32"
                        text="Address"
                        required="true"
                        
                    />
                    <Input
                        id="input32"
                        xmlns="sap.m"
                        placeholder="Enter Your Address"
                        class="sapUiTinyMarginBegin"
                        enabled="true"
                    />
                </form:content>
            </form:SimpleForm>

            <FlexBox
                id="Hbox1"
                justifyContent="Center"
            >
                <Button
                    id="btn"
                    text="Go"
                    type="Accept"
                    press="onsubmitgo"
                />
                <Button
                    id="btnn"
                    text="Reset"
                    type="Reject"
                    class="sapUiTinyMarginBegin"
                    press="onResetPress"
                />
            </FlexBox>
            
