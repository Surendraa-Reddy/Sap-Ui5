<mvc:View
    controllerName="ui5.controller.update"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core">

    <Page
        title="Update Employee"
        showNavButton="true"
        navButtonPress="onBack">

        <content>

            <form:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout">

                <form:content>

                    <Label text="Id"/>
                    <Input  id="inpId" value="{Id}" editable="false" width="30%"/>

                    <Label text="Name"/>
                    <Input value="{Name}" width="30%"/>

                    <Label text="Age"/>
                    <Input value="{Age}" width="30%"/>

                    <Label text="Email"/>
                    <Input value="{Email}" width="30%"/>

                    <Label text="Gender"/>
                    <Input value="{Gender}" width="30%"/>

                    <Label text="Mobile"/>
                    <Input value="{Mobile}" width="30%"/>

                    <Label text="Address"/>
                    <Input value="{Address}" width="30%"/>

                </form:content>

            </form:SimpleForm>
             <Table id="projectTable2"  items="{editprjModel>/results}" headerText="Projects" >

            <headerToolbar>
                <Toolbar>
                    <Title text=" Edit Projects"/>
                
                <ToolbarSpacer></ToolbarSpacer>
                <Button
                   icon="sap-icon://add"
                   type="Emphasized"
                   press="onAddProject"/>
                </Toolbar>
            </headerToolbar>
            <columns>
            <Column >
                <Text text="Id"/>
            </Column>
            <Column >
                <Text text="Project Name"/>
            </Column>
            <Column >
                <Text text="Project Code"/>
            </Column>
            <Column >
                <Text text="Client"/>
            </Column>
            <Column >
                <Text text="Project Description"/>
            </Column>
            <Column >
                <Text text="Team Size"/>
            </Column>
             <Column >
                <Text text="Delete"/>
            </Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Input value="{editprjModel>Id}"/>
                        <Input value="{editprjModel>ProjectName}"/>
                        <Input value="{editprjModel>PrjCode}"/>
                        <Input value="{editprjModel>Client}"/>
                        <Input value="{editprjModel>PrjDescription}"/>
                        <Input value="{editprjModel>TeamSize}"/>
                        <Button icon="sap-icon://delete" type="Reject" press="onDeleteProject"/>
                    </cells>
                </ColumnListItem>
            </items>
            </Table>

            <Toolbar>
                <ToolbarSpacer/>

                <Button
                    text="Update"
                    type="Emphasized"
                    press="onUpdateEmployee"/>

                <Button
                    text="Cancel"
                    type="Reject"
                    press="onBack"/>
            </Toolbar>

             <form:SimpleForm
                id="UploadForm1"
                editable="true"
                layout="ResponsiveGridLayout"
                title="Upload Employee Image"
                class="sapUiMediumMargin"
                labelSpanL="4"
                labelSpanM="4"
                columnsL="3"
                columnsM="3">
                <form:content>
              
                    <Label text="Upload Employee Image" required="true"/>
                    <u:FileUploader id="fileUploader2" name="myFileUpload" uploadUrl="/sap/opu/odata/sap/ZODATA_EMPLOYEE_SRV_01/PhotosSet" sendXHR="true" useMultipart="false"
                     change="onFileChange" uploadComplete="onUploadComplete"/>
                    <Button  id="btnUpload2" text="Upload" press="onUploadfile" type="Emphasized" width="30%"/>

                </form:content>
                </form:SimpleForm>

        </content>

    </Page>

</mvc:View>